# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of origins permitted to call the API.
# Required in production. In development, leave unset to reflect any origin.
# Example:
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:3001

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=daily-report

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_FILE_PATH=./logs/app.log
LOG_LEVEL=info
# Days before MongoDB TTL evicts log documents. Default: 30.
LOG_RETENTION_DAYS=30

# ─── Rate limiting (defaults shown) ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
STRICT_RATE_LIMIT_WINDOW_MS=900000
STRICT_RATE_LIMIT_MAX=10
AUTH_IP_LIMIT_WINDOW_MS=900000
AUTH_IP_LIMIT_MAX=20
AUTH_USERNAME_LIMIT_WINDOW_MS=900000
AUTH_USERNAME_LIMIT_MAX=10

# ─── Active Directory ────────────────────────────────────────────────────────
AD_URL=ldap://your-ad-host
AD_BASE_DN=DC=example,DC=com
AD_USERNAME=
AD_PASSWORD=
